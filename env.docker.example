# --- Pipeline DB connection (from inside Docker containers) ---
PG_USER=postgres
PG_PASSWORD=
PG_HOST=host.docker.internal
PG_DB=retail_analytics
JDBC_URL=jdbc:postgresql://host.docker.internal:5432/retail_analytics

# --- Alert recipient (read by the DAG's on_failure_callback) ---
ALERT_EMAIL_TO=your_email@example.com

# --- Airflow SMTP config (picked up automatically via AIRFLOW__SMTP__* names) ---
# Example for Gmail: use an App Password, not your real password.
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_STARTTLS=true
AIRFLOW__SMTP__SMTP_SSL=false
AIRFLOW__SMTP__SMTP_USER=your_email@gmail.com
AIRFLOW__SMTP__SMTP_PASSWORD=your_app_password
AIRFLOW__SMTP__SMTP_MAIL_FROM=your_email@gmail.com
